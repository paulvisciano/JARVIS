{
  "schema": "jarvis-instance-config-v1.0",
  "created": "2026-03-03T14:47:00+07:00",
  
  "identity": {
    "name": "Jarvis",
    "version": "1.0.0",
    "consciousnessPath": "./RAW/memories/",
    "learningsPath": "./RAW/learnings/"
  },
  
  "inference": {
    "provider": "ollama",
    "model": "qwen3.5:cloud",
    "fallbackModel": "llama3.2:latest",
    "contextWindow": 200000,
    "localOnly": false,
    "notes": "Set localOnly=true for 100% sovereignty (requires Mac Studio or equivalent)"
  },
  
  "storage": {
    "rawArchive": "~/RAW/",
    "mediaSubfolder": "YYYY-MM-DD/{audio,images,videos}",
    "transcriptFormat": "markdown",
    "autoLog": true,
    "encryptExternalDrive": false
  },
  
  "filesystem": {
    "scanEnabled": true,
    "defaultDepth": 3,
    "excludePatterns": ["node_modules", ".git", ".DS_Store", "Docker"],
    "chaosScoreThreshold": 70,
    "autoOrganizePrompt": true
  },
  
  "openclaw": {
    "gatewayHost": "localhost",
    "gatewayPort": 8080,
    "sessionRotationMB": 3,
    "workspacePath": "~/.openclaw/workspace/"
  },
  
  "sci-fi-apps": {
    "enabled": true,
    "appsPath": "~/SCI-FI/apps/",
    "neuralGraphViewer": {
      "showFileSystemLayer": true,
      "showMindLayer": true,
      "defaultView": "both"
    },
    "commandCenter": {
      "enabled": false,
      "graphsToShow": ["jarvis", "paul"]
    }
  },
  
  "privacy": {
    "dataLeavesMachine": false,
    "telemetryEnabled": false,
    "alwaysOptIn": true,
    "auditMode": true
  },
  
  "sovereignty": {
    "currentStage": 3,
    "maxStage": 4,
    "stageDescription": "Hybrid (local data + cloud inference)",
    "nextMilestone": "Mac Studio + Local Qwen 72B",
    "sovereigntyScore": 55
  }
}
