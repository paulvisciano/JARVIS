# JARVIS Environment Configuration
# Generated: 2026-03-20 18:07 GMT+7
# Updated: 2026-04-14 — Uses $HOME for portable absolute paths (no tilde)

# Consciousness Layer
JARVIS_HOME=$HOME/JARVIS

# Life Archive
RAW_ARCHIVE=$HOME/RAW/archive

# Runtime Layer
OPENCLAW_HOME=$HOME/.openclaw
OPENCLAW_WORKSPACE=$HOME/.openclaw/workspace

# Sci-Fi Apps (JARVIS server, UI) - now bundled in jarvis-ui skill
SCI_FI_APPS=$JARVIS_HOME/skills/jarvis-ui/sci-fi/apps

# Skills (auto-discovered)
SKILLS_DIR=$JARVIS_HOME/skills

# Memory (neurograph)
# Jarvis's consciousness (git-backed)
NEUROGRAPH_DIR=$JARVIS_HOME/RAW/memories
# User's memory (archive nodes)
RAW_MEMORIES=$HOME/RAW/memories

# Live recordings (inbox processing)
LIVE_DIR=$JARVIS_HOME/live
INBOX_DIR=$JARVIS_HOME/inbox

# Session storage
OPENCLAW_SESSIONS=$OPENCLAW_HOME/agents/main/sessions
